# PowerShell scripts: 按字节原样存储 (含 UTF-8 BOM, 保护中文).
# 不用 working-tree-encoding=UTF-8-BOM - 那会做编码转换, 遇非法 UTF-8 字节就炸.
# binary 属性阻止 git 做任何 CRLF/编码转换, 原样 commit.
*.ps1 -text
*.psm1 -text
*.psd1 -text

# AHK 同理
*.ahk -text

# Markdown / YAML / JSON: LF is fine
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Binary (should not appear in this repo, but guard)
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
